# Server
PORT=3000

# Database
DATABASE_URL="mongodb+srv://<db-user>:<db-password>@<cluster>/<database>?retryWrites=true&w=majority"

# Auth
JWT_SECRET=replace_with_a_long_random_secret

# Mail
MAIL_HOST=smtp.gmail.com
MAIL_USER=replace_with_mail_user
MAIL_PASS=replace_with_mail_app_password
MAIL_PORT=587
MAIL_SECURE=false
MAIL_FROM="KirtanSarthi <replace_with_mail_user>"
# Set to false only if your hosting SMTP provider uses self-signed/invalid certs.
MAIL_TLS_REJECT_UNAUTHORIZED=true

# Cloudinary
FOLDER_NAME="KirtanSarthi"
CLOUD_NAME=replace_with_cloudinary_cloud_name
API_KEY=replace_with_cloudinary_api_key
API_SECRET=replace_with_cloudinary_api_secret

# AI
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_API_KEY=replace_with_groq_api_key

# Client origins (comma-separated allowed in CORS_ORIGINS if needed)
FRONTEND_URL=https://your-frontend-domain.com
CLIENT_URL=https://your-frontend-domain.com
CORS_ORIGINS=https://your-frontend-domain.com,https://www.your-frontend-domain.com

# Nearby events radius (meters)
NEARBY_RADIUS=10000
